# Database (Supabase or Railway Postgres)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Server
PORT=3000
NODE_ENV=development

# Auth - generate a random secret for production
JWT_SECRET=your-secret-key-here

# Frontend URLs for CORS (comma-separated)
FRONTEND_URLS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Railway specific (auto-populated by Railway when using Postgres addon)
# DATABASE_URL is auto-set by Railway
