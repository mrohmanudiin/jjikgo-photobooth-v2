generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Branch {
  id           Int           @id @default(autoincrement())
  name         String
  location     String?
  active       Boolean       @default(true)
  created_at   DateTime      @default(now())
  booths       Booth[]
  settings     Setting[]
  shifts       Shift[]
  themes       Theme[]
  transactions Transaction[]
  users        User[]
}

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  password     String
  full_name    String?
  role         String        @default("staff")
  branch_id    Int?
  active       Boolean       @default(true)
  created_at   DateTime      @default(now())
  shifts       Shift[]
  transactions Transaction[]
  branch       Branch?       @relation(fields: [branch_id], references: [id])
}

model Shift {
  id             Int           @id @default(autoincrement())
  branch_id      Int
  user_id        Int
  start_time     DateTime      @default(now())
  end_time       DateTime?
  starting_cash  Float         @default(0)
  ending_cash    Float?        @default(0)
  total_expenses Float         @default(0)
  status         String        @default("open")
  expenses       Expense[]
  branch         Branch        @relation(fields: [branch_id], references: [id])
  user           User          @relation(fields: [user_id], references: [id])
  transactions   Transaction[]
}

model Expense {
  id          Int      @id @default(autoincrement())
  shift_id    Int
  amount      Float
  description String
  time        DateTime @default(now())
  shift       Shift    @relation(fields: [shift_id], references: [id])
}

model Theme {
  id           Int           @id @default(autoincrement())
  name         String
  booth_number String?
  price        Float
  active       Boolean       @default(true)
  color        String?
  prefix       String?       @default("T")
  max_capacity Int           @default(4)
  branch_id    Int?
  booths       Booth[]
  queues       Queue[]
  branch       Branch?       @relation(fields: [branch_id], references: [id])
  transactions Transaction[]
}

model Package {
  id          Int     @id @default(autoincrement())
  slug        String  @unique
  label       String
  price       Float
  description String?
  prints      Int     @default(0)
  active      Boolean @default(true)
}

model Addon {
  id     Int     @id @default(autoincrement())
  label  String
  price  Float
  active Boolean @default(true)
}

model CafeSnack {
  id     Int     @id @default(autoincrement())
  label  String
  price  Float
  active Boolean @default(true)
}

model Promo {
  id       Int     @id @default(autoincrement())
  label    String
  discount Float
  type     String
  active   Boolean @default(true)
}

model Transaction {
  id             Int      @id @default(autoincrement())
  invoice_number String   @unique
  customer_name  String
  customer_email String?
  theme_id       Int
  package_name   String
  payment_method String
  total_price    Float
  status         String   @default("waiting")
  created_at     DateTime @default(now())
  addons         Json?
  cafe_snacks    Json?
  promo          String?
  people_count   Int      @default(1)
  note           String?
  branch_id      Int?
  shift_id       Int?
  user_id        Int?
  queue          Queue[]
  branch         Branch?  @relation(fields: [branch_id], references: [id])
  shift          Shift?   @relation(fields: [shift_id], references: [id])
  theme          Theme    @relation(fields: [theme_id], references: [id])
  user           User?    @relation(fields: [user_id], references: [id])
}

model Queue {
  id             Int         @id @default(autoincrement())
  transaction_id Int
  theme_id       Int
  booth_id       Int?
  queue_number   Int
  status         String      @default("waiting")
  created_at     DateTime    @default(now())
  booth          Booth?      @relation(fields: [booth_id], references: [id])
  theme          Theme       @relation(fields: [theme_id], references: [id])
  transaction    Transaction @relation(fields: [transaction_id], references: [id])
}

model Booth {
  id        Int     @id @default(autoincrement())
  name      String
  theme_id  Int
  status    String  @default("available")
  branch_id Int?
  queues    Queue[]
  branch    Branch? @relation(fields: [branch_id], references: [id])
  theme     Theme   @relation(fields: [theme_id], references: [id])
}

model Setting {
  key       String
  value     String
  branch_id Int?
  id        Int     @id @default(autoincrement())
  branch    Branch? @relation(fields: [branch_id], references: [id])

  @@unique([branch_id, key])
}
