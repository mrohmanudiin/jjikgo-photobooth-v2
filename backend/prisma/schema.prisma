generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Theme {
  id           Int           @id @default(autoincrement())
  name         String
  prefix       String?       @default("T") // For queue numbers like T01
  color        String?       // Hex color if needed
  booth_number String?
  price        Float
  active       Boolean       @default(true)
  transactions Transaction[]
  queues       Queue[]
  booths       Booth[]
}

model Package {
  id          Int      @id @default(autoincrement())
  slug        String   @unique // e.g., 'basic', 'premium'
  label       String
  price       Float
  description String?
  prints      Int      @default(0)
  active      Boolean  @default(true)
}

model Addon {
  id     Int      @id @default(autoincrement())
  label  String
  price  Float
  active Boolean  @default(true)
}

model CafeSnack {
  id     Int      @id @default(autoincrement())
  label  String
  price  Float
  active Boolean  @default(true)
}

model Promo {
  id       Int      @id @default(autoincrement())
  label    String
  discount Float
  type     String   // 'percent', 'flat', 'manual'
  active   Boolean  @default(true)
}

model Transaction {
  id             Int      @id @default(autoincrement())
  invoice_number String   @unique
  customer_name  String
  customer_email String?
  theme_id       Int
  package_name   String
  payment_method String
  total_price    Float
  status         String   @default("waiting") // waiting, shooting, finished
  created_at     DateTime @default(now())

  theme Theme   @relation(fields: [theme_id], references: [id])
  queue Queue[]
}

model Queue {
  id             Int      @id @default(autoincrement())
  transaction_id Int
  theme_id       Int
  queue_number   Int
  status         String   @default("waiting") // waiting, called, in_progress, finished
  created_at     DateTime @default(now())

  transaction Transaction @relation(fields: [transaction_id], references: [id])
  theme       Theme       @relation(fields: [theme_id], references: [id])
}

model Booth {
  id       Int    @id @default(autoincrement())
  name     String
  theme_id Int
  status   String @default("available") // available, busy

  theme Theme @relation(fields: [theme_id], references: [id])
}

model Setting {
  key   String @id
  value String
}
